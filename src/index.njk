---
layout: layouts/base.njk
---

<h1>{{ site.name }}</h1>
<p class="hero-description">{{ site.description }}</p>

{% if collections.allArticles.length > 0 %}
<section class="latest-articles">
  <h2>Latest Guides &amp; Comparisons</h2>
  <div class="article-list">
    {% for post in collections.allArticles | limit(12) %}
    <article class="article-card">
      <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
      {% if post.data.description %}<p>{{ post.data.description }}</p>{% endif %}
      <div class="card-meta">
        {% if post.data.category %}<span class="badge">{{ post.data.category }}</span>{% endif %}
        {% if post.data.date %}<time datetime="{{ post.data.date }}">{{ post.data.date | readableDate }}</time>{% endif %}
      </div>
    </article>
    {% endfor %}
  </div>
</section>
{% else %}
<section class="welcome">
  <h2>Welcome</h2>
  <p>Content is being added. Check back soon for expert comparisons and how-to guides.</p>
</section>
{% endif %}

{% if collections.categories.length > 0 %}
<section class="categories">
  <h2>Browse by Category</h2>
  <div class="category-list">
    {% for cat in collections.categories %}
    <a href="/category/{{ cat | slugify }}/" class="category-tag">{{ cat }}</a>
    {% endfor %}
  </div>
</section>
{% endif %}