<!DOCTYPE html>
<html lang="{{ site.language }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{% if description %}{{ description | escape }}{% else %}{{ site.description | escape }}{% endif %}">
  <meta name="theme-color" content="#0f172a">
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/images/branding/zeroflow-favicon.svg">
  <!-- Preload CSS for faster rendering -->
  <link rel="preload" href="/assets/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/assets/css/style.css"></noscript>
  <!-- Open Graph -->
  <meta property="og:title" content="{% if title %}{{ title | escape }}{% else %}{{ site.name | escape }}{% endif %}">
  <meta property="og:description" content="{% if description %}{{ description | escape }}{% else %}{{ site.description | escape }}{% endif %}">
  <meta property="og:type" content="{% if ogType %}{{ ogType }}{% else %}website{% endif %}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:locale" content="{{ site.locale }}">
  <meta property="og:image" content="{{ site.url }}/assets/images/branding/zeroflow-favicon.svg">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  {% if site.social.twitter %}<meta name="twitter:site" content="@{{ site.social.twitter }}">{% endif %}
  <meta name="twitter:title" content="{% if title %}{{ title | escape }}{% else %}{{ site.name | escape }}{% endif %}">
  <meta name="twitter:description" content="{% if description %}{{ description | escape }}{% else %}{{ site.description | escape }}{% endif %}">
  <!-- Canonical -->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.name }}</title>
  <!-- Schema JSON-LD -->
  {% if title and description %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "{% if schemaType %}{{ schemaType }}{% else %}WebPage{% endif %}",
    "name": "{{ title | escape }}",
    "description": "{{ description | escape }}",
    "url": "{{ site.url }}{{ page.url }}",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ site.url }}{{ page.url }}"
    }
  }
  </script>
  {% endif %}
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a class="logo" href="/" aria-label="{{ site.name }} Home">
        <img src="/assets/images/branding/zeroflow-logo.svg" alt="{{ site.name }}" width="180" height="60" fetchpriority="high">
      </a>
      <nav class="main-nav" aria-label="Main navigation">
        <ul>
          {% for item in navigation %}
          <li><a href="{{ item.url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.label }}</a></li>
          {% endfor %}
        </ul>
      </nav>
    </div>
  </header>
  <div class="page-layout{% if showSidebar == false %} page-layout--full{% endif %}">
    <main class="main-content" id="main-content">
      {{ content | safe }}
    </main>
    {% if showSidebar != false %}
    {% include "sidebar.njk" %}
    {% endif %}
  </div>
  <footer class="site-footer">
    <div class="container">
      <p class="affiliate-disclaimer">{{ affiliates.disclaimer }}</p>
      <p>&copy; {% year %} {{ site.name }}. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>