---
layout: layouts/base.njk
pagination:
  data: collections.categories
  size: 1
  alias: category
  filter: []
permalink: "/category/{{ category | slugify }}/"
eleventyComputed:
  title: "{{ category }}"
  description: "Articles in the {{ category }} category"
---

<h1>Category: {{ category }}</h1>
<div class="article-list">
  {% set articles = collections.allArticles | where("category", category) %}
  {% for post in articles %}
  <article class="article-card">
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {% if post.data.description %}<p>{{ post.data.description }}</p>{% endif %}
    <div class="card-meta">
      {% if post.data.date %}<time datetime="{{ post.data.date }}">{{ post.data.date | readableDate }}</time>{% endif %}
    </div>
  </article>
  {% endfor %}
</div>