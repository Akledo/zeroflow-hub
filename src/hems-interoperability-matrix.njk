<!-- Brevo API Form Integration -->
<form class="zf-form" action="#" onsubmit="return sendBrevoForm(this)">
  <div class="zf-form-group">
    <label for="NAME">Your Name</label>
    <input type="text" name="NAME" class="zf-input" placeholder="First name" required>
  </div>
  <div class="zf-form-group">
    <label for="EMAIL">Email Address</label>
    <input type="email" name="EMAIL" class="zf-input" placeholder="your@email.com" required>
  </div>
  <button type="submit" class="zf-btn">Send Me the Download →</button>
  <p class="zf-form-disclaimer">No spam. Unsubscribe anytime.</p>
</form>
<script>
async function sendBrevoForm(form) {
  const btn = form.querySelector('.zf-btn');
  btn.textContent = 'Sending...';
  btn.disabled = true;
  try {
    const data = { email: form.EMAIL.value, name: form.NAME.value, listIds: [2] };
    const r = await fetch('https://api.brevo.com/v3/contacts', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'api-key': 'BREVO_API_KEY_PLACEHOLDER' },
      body: JSON.stringify(data)
    });
    if (r.ok) { form.innerHTML = '<p class="zf-success">✅ Check your inbox!</p>'; }
    else { form.innerHTML = '<p class="zf-error">⚠️ Error. Try again.</p>'; }
  } catch(e) { form.innerHTML = '<p class="zf-error">⚠️ Network error.</p>'; }
  return false;
}
</script>
